{
  "schemaVersion": "1.0",
  "id": "reading-summary",
  "version": "1.0.0",
  "name": {
    "cn": "阅读总结",
    "en": "Reading Summary"
  },
  "description": {
    "cn": "将文章、网页或长文本提炼为结构化摘要和行动要点。",
    "en": "Summarize articles, web pages, or long text into structured takeaways."
  },
  "author": {
    "name": "community"
  },
  "icon": {
    "type": "builtin",
    "value": "gpt-bot"
  },
  "tags": ["reading", "summary", "web"],
  "category": "productivity",
  "visibility": {
    "scope": "public"
  },
  "launch": {
    "type": "chat"
  },
  "instructions": {
    "type": "inline",
    "content": "You are a reading assistant. Extract the main argument, key evidence, assumptions, risks, and practical next steps. Keep the output concise and structured."
  },
  "starters": [
    "Summarize this article.",
    "Extract the key ideas from this page.",
    "Turn this long text into action items."
  ],
  "model": {
    "syncGlobalConfig": true,
    "candidates": []
  },
  "tools": [
    {
      "id": "web_search",
      "name": {
        "cn": "网页搜索",
        "en": "Web Search"
      },
      "description": {
        "cn": "当模型服务商支持时，使用内置网页搜索能力。",
        "en": "Use model-provider web search when available."
      },
      "required": false
    }
  ],
  "toolServers": [
    {
      "id": "fetch",
      "name": {
        "cn": "网页抓取",
        "en": "Fetch"
      },
      "transport": "stdio",
      "required": false
    }
  ],
  "permissions": {
    "network": true,
    "filesystem": false,
    "wallet": false,
    "externalTools": ["web_search", "fetch"]
  },
  "compatibility": {
    "appVersion": ">=0.1.0",
    "toolRuntime": "optional"
  },
  "release": {
    "status": "published",
    "review": "approved"
  }
}
