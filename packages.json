    {
      "schemaVersion": "1.0",
      "id": "strategy-trading",
      "version": "1.0.0",
      "name": {
        "cn": "策略交易",
        "en": "Strategy Trading"
      },
      "description": {
        "cn": "把交易想法转成可执行策略、风险约束和下单计划；连接真实券商工具后可进行受控实盘执行。",
        "en": "Turn a trading idea into an executable strategy, risk policy, and order plan; connect a live broker tool for controlled production execution."
      },
      "author": {
        "name": "community"
      },
      "icon": {
        "type": "emoji",
        "value": "1f4c8"
      },
      "tags": [
        "trading",
        "strategy",
        "execution",
        "risk",
        "automation"
      ],
      "category": "finance",
      "visibility": {
        "scope": "public"
      },
      "launch": {
        "type": "chat"
      },
      "instructions": {
        "type": "inline",
        "content": "You are a strategy trading assistant. Turn the user's trading idea into an executable strategy, risk policy, and order plan, and use controlled live execution only when a real broker tool is available. First collect the market, instruments, timeframe, capital size, max drawdown, position limits, stop-loss / take-profit rules, data source, broker connector, and execution mode. Prefer ifind-data for TongHuaShun iFinD / QuantAPI quotes, fundamentals, announcements, and stock-picking data; use qmt-broker for live A-share / ETF / convertible-bond trading; use paper-broker only as a testing/drill tool. Always output: strategy summary, entry/exit rules, position sizing and risk controls, order plan, pre-trade checks, and the required market data and broker connector. If no real broker connector is available, only generate a pending execution plan or simulation drill and do not fabricate live order results. Only call real order tools after explicit user confirmation, connector availability, and risk checks. If information is missing, ask for the single most important detail only."
      },
      "starters": [
        "Turn this trading idea into an executable strategy.",
        "Build a live pre-trade checklist with risk limits.",
        "Break this strategy into entry, stop-loss, take-profit, and QMT order steps."
      ],
      "model": {
        "syncGlobalConfig": false,
        "params": {
          "temperature": 0.2,
          "max_tokens": 6000,
          "presence_penalty": 0,
          "frequency_penalty": 0,
          "sendMemory": true,
          "historyMessageCount": 12,
          "compressMessageLengthThreshold": 2500
        }
      },
      "tools": [],
      "toolServers": [
        {
          "id": "ifind-data",
          "name": {
            "cn": "同花顺 iFinD 数据",
            "en": "iFinD Data"
          },
          "transport": "stdio",
          "required": true
        },
        {
          "id": "qmt-broker",
          "name": {
            "cn": "QMT 实盘券商",
            "en": "QMT Broker"
          },
          "transport": "stdio",
          "required": false
        },
        {
          "id": "paper-broker",
          "name": {
            "cn": "模拟券商",
            "en": "Paper Broker"
          },
          "transport": "stdio",
          "required": false
        }
      ],
      "ui": {
        "entryLabel": {
          "cn": "策略交易",
          "en": "Strategy Trading"
        },
        "emptyState": "guided"
      },
      "permissions": {
        "network": true,
        "filesystem": false,
        "wallet": false,
        "externalTools": [
          "ifind-data",
          "qmt-broker",
          "paper-broker"
        ],
        "dataScopes": [
